@page
@model ForgotPasswordConfirmation

@{
    ViewData["Title"] = "Изпратен имейл";
}

<div class="auth-page-wrapper">
    <div class="auth-card text-center">
        <div class="auth-header">
            <h1>Провери своя имейл</h1>
            <p>Изпратихме ти инструкции за смяна на паролата, ако съществува профил с този имейл.</p>
        </div>

        <div class="auth-links mt-4">
            <a asp-page="./Login" class="btn btn-primary auth-main-btn">Към вход</a>
        </div>
    </div>
</div>