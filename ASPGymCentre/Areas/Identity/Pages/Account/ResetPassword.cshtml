@page
@model ResetPasswordModel

@{
    ViewData["Title"] = "Нова парола";
}

<div class="auth-page-wrapper">
    <div class="auth-card">
        <div class="auth-header">
            <h1>Нова парола</h1>
            <p>Въведи имейла си и избери нова парола.</p>
        </div>

        <form method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <input asp-for="Input.Code" type="hidden" />

            <div class="form-group mb-3">
                <label asp-for="Input.Email">Имейл</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="Въведи имейл" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Input.Password">Нова парола</label>
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" placeholder="Въведи нова парола" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Input.ConfirmPassword">Потвърди парола</label>
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="Повтори новата парола" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 auth-main-btn">
                Запази новата парола
            </button>

            <div class="auth-links mt-4">
                <a asp-page="./Login">Към вход</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}