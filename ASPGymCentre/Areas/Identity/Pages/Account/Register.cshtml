@page
@model RegisterModel

@{
    ViewData["Title"] = "Регистрация";
}

<div class="auth-page-wrapper">
    <div class="auth-card">
        <div class="auth-header">
            <h1>Регистрация</h1>
            <p>Създай профил, за да можеш да се записваш за тренировки и да следиш своите заявки.</p>
        </div>

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="form-group mb-3">
                <label asp-for="Input.Email">Имейл</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="Въведи имейл" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Input.UserName">Потребителско име</label>
                <input asp-for="Input.UserName" class="form-control" aria-required="true" placeholder="Въведи потребителско име" />
                <span asp-validation-for="Input.UserName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Input.Name">Име</label>
                <input asp-for="Input.Name" class="form-control" aria-required="true" placeholder="Въведи име" />
                <span asp-validation-for="Input.Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Input.FamilyName">Фамилия</label>
                <input asp-for="Input.FamilyName" class="form-control" aria-required="true" placeholder="Въведи фамилия" />
                <span asp-validation-for="Input.FamilyName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Input.PhoneNumber">Телефонен номер</label>
                <input asp-for="Input.PhoneNumber" class="form-control" aria-required="true" placeholder="Въведи телефонен номер" />
                <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Input.Password">Парола</label>
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Въведи парола" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Input.ConfirmPassword">Потвърди парола</label>
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Повтори паролата" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <button id="registerSubmit" type="submit" class="btn btn-primary w-100 auth-main-btn">
                Регистрация
            </button>

            <div class="auth-links mt-4">
                <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Вече имаш акаунт? Влез</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}