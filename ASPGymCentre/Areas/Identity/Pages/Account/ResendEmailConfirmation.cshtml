@page
@model ResendEmailConfirmationModel

@{
    ViewData["Title"] = "Изпращане на потвърждение";
}

<div class="auth-page-wrapper">
    <div class="auth-card">
        <div class="auth-header">
            <h1>Изпращане на потвърждение</h1>
            <p>Въведи своя имейл адрес, за да получиш нов имейл за потвърждение на профила.</p>
        </div>

        <form method="post" class="auth-form">
            <div asp-validation-summary="All" class="text-danger" role="alert"></div>

            <div class="form-group mb-3">
                <label asp-for="Input.Email">Имейл</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="Въведи имейл" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 auth-main-btn">
                Изпрати потвърждение
            </button>

            <div class="auth-links mt-4">
                <a asp-page="./Login">Към вход</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}