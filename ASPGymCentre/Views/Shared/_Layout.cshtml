<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ASPGymCentre</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ASPGymCentre.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg custom-navbar shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    „Желязна сила“
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Превключване на менюто">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav mx-auto mb-2 mb-lg-0 custom-menu">
                        <li class="nav-item">
                            <a class="nav-link menu-btn" asp-area="" asp-controller="Home" asp-action="Index">Начало</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link menu-btn" asp-area="" asp-controller="Plans" asp-action="Index">Планове</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link menu-btn" asp-area="" asp-controller="PlanCategories" asp-action="Index">Категории планове</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link menu-btn" asp-area="" asp-controller="Exercises" asp-action="Index">Тренировки</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link menu-btn" asp-area="" asp-controller="Instructors" asp-action="Index">Инструктори</a>
                        </li>

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link menu-btn" asp-area="" asp-controller="Reservations" asp-action="Index">Резервации</a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link menu-btn" asp-area="" asp-controller="Reservations" asp-action="MyReservations">Моите резервации</a>
                                </li>
                            }
                        }

                        <li class="nav-item">
                            <a class="nav-link menu-btn" asp-area="" asp-controller="Home" asp-action="About">За нас</a>
                        </li>
                    </ul>

                    <div class="login-area">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container page-container">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="custom-footer">
        <div class="container text-center">
            &copy; 2026 - ASPGymCentre
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>