@{
    ViewData["Title"] = "Галерия";
}

<section class="info-hero-box">
    <span class="section-kicker">Атмосфера и среда</span>
    <h1>Галерия</h1>
    <p>
        Разгледай атмосферата във фитнес център „Желязна сила“.
        Натисни върху снимка, за да я отвориш в по-голям размер.
    </p>
</section>

<div class="gallery-grid">

    <div class="gallery-card">
        <img class="gallery-clickable"
             src="~/images/fitneszala.png"
             data-full="/images/fitneszala.png"
             alt="Фитнес зала" />
        <div class="gallery-card-overlay">Фитнес зала</div>
    </div>

    <div class="gallery-card">
        <img class="gallery-clickable"
             src="~/images/fitnestejesti.png"
             data-full="/images/fitnestejesti.png"
             alt="Тренировка с тежести" />
        <div class="gallery-card-overlay">Тренировка с тежести</div>
    </div>

    <div class="gallery-card">
        <img class="gallery-clickable"
             src="~/images/kardiozona.png"
             data-full="/images/kardiozona.png"
             alt="Кардио зона" />
        <div class="gallery-card-overlay">Кардио зона</div>
    </div>

    <div class="gallery-card">
        <img class="gallery-clickable"
             src="~/images/grupovatrenirovka.png"
             data-full="/images/grupovatrenirovka.png"
             alt="Групова тренировка" />
        <div class="gallery-card-overlay">Групова тренировка</div>
    </div>

    <div class="gallery-card">
        <img class="gallery-clickable"
             src="~/images/oborudvane.png"
             data-full="/images/oborudvane.png"
             alt="Фитнес оборудване" />
        <div class="gallery-card-overlay">Фитнес оборудване</div>
    </div>

    <div class="gallery-card">
