@model ASPGymCentre.Models.Plan

@{
    ViewData["Title"] = "Детайли";
}

<h1>Детайли</h1>

<div class="details-box">
    <h4>План</h4>
    <hr />

    <div class="details-grid">
        <div class="details-label">Име</div>
        <div class="details-value">@Model.Name</div>

        <div class="details-label">Категория</div>
        <div class="details-value">@Model.PlansCategories?.Name</div>

        <div class="details-label">Описание</div>
        <div class="details-value">@Model.Description</div>

        <div class="details-label">Снимка</div>
        <div class="details-value">
            <img src="@Model.Image" alt="Снимка на план" class="details-image" />
        </div>

        <div class="details-label">Цена за една тренировка</div>
        <div class="details-value">@Model.PriceSingleWorkout</div>

        <div class="details-label">Дата на регистрация</div>
        <div class="details-value">@Model.RegisteredDate</div>
    </div>

    <div class="page-actions">
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm action-btn">Редактирай</a>
        }

        <a asp-action="Index" class="btn btn-secondary btn-sm page-btn">Обратно към списъка</a>
    </div>
</div>