@model ASPGymCentre.Models.Exercise

@{
    ViewData["Title"] = "Детайли";
}

<h1>Детайли</h1>

<div class="details-box">
    <h4>Тренировка</h4>
    <hr />

    <div class="details-grid">
        <div class="details-label">План</div>
        <div class="details-value">@Model.Plans?.Name</div>

        <div class="details-label">Ден</div>
        <div class="details-value">@Model.Day</div>

        <div class="details-label">Начален час</div>
        <div class="details-value">@Model.StartTime</div>

        <div class="details-label">Краен час</div>
        <div class="details-value">@Model.EndTime</div>

        <div class="details-label">Инструктор</div>
        <div class="details-value">@Model.Instructors?.Name</div>

        <div class="details-label">Дата на регистрация</div>
        <div class="details-value">@Model.RegisteredDate</div>
    </div>

    <div class="page-actions">
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm action-btn">Редактирай</a>
        }

        <a asp-action="Index" class="btn btn-secondary btn-sm page-btn">Обратно към списъка</a>
    </div>
</div>