@model IEnumerable<ASPGymCentre.Models.Exercise>

@{
    ViewData["Title"] = "Тренировки";
}

<div class="section-title-row">

    <h1>Тренировки</h1>

    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create"
           class="btn btn-primary">

            Създай нова тренировка

        </a>
    }

</div>


@if (Model != null && Model.Any())
{
    <div class="card-grid">

        @foreach (var item in Model)
        {
            <div class="custom-card">

                <img src="@($"/images/{item.Plans?.Image}")"
                     class="custom-card-img">

                <div class="custom-card-body">

                    <div class="badge-soft">
                        @item.Plans?.Name
                    </div>


                    <h3 class="custom-card-title">
                        @item.Day
                    </h3>


                    <div class="custom-card-meta">
                        <strong>Час:</strong>
                        @item.StartTime - @item.EndTime
                    </div>


                    <div class="custom-card-meta">
                        <strong>Инструктор:</strong>
                        @item.Instructors?.Name
                    </div>


                    <div class="custom-card-meta">
                        <strong>Цена:</strong>
                        @item.Plans?.PriceSingleWorkout €
                    </div>


                    <div class="custom-card-meta">
                        <strong>Добавена на:</strong>
                        @item.RegisteredDate.ToShortDateString()
                    </div>


                    <div class="custom-card-footer">

                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-primary btn-sm action-btn">

                                Редактирай

                            </a>
                        }


                        <a asp-action="Details"
                           asp-route-id="@item.Id"
                           class="btn btn-info btn-sm action-btn">

                            Детайли

                        </a>


                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-danger btn-sm action-btn">

                                Изтрий

                            </a>
                        }

                    </div>

                </div>

            </div>
        }

    </div>
}
else
{
    <div class="empty-box">
        Няма добавени тренировки.
    </div>
}