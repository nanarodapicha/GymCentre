@model ASPGymCentre.Models.Reservation

@{
    ViewData["Title"] = "Редактиране";
}

<h1>Редактиране</h1>

<h4>Резервация</h4>
<hr />

<div class="form-page-box">
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ClientId" />

                <div class="form-group mb-3">
                    <label asp-for="ExerciseId" class="control-label">Тренировка</label>
                    <select asp-for="ExerciseId" class="form-control" asp-items="ViewBag.ExerciseId">
                        <option value="0">-- Избери тренировка --</option>
                    </select>
                    <span asp-validation-for="ExerciseId" class="text-danger"></span>
                </div>

                <div class="page-actions">
                    <input type="submit" value="Запази" class="btn btn-primary" />
                    <a asp-action="Index" class="btn btn-secondary page-btn">Обратно към списъка</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}