@model ASPGymCentre.Models.Reservation

@{
    ViewData["Title"] = "Създаване";
}

<h1>Създаване на резервация</h1>

<h4>Резервация</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="ExerciseId" class="control-label">Тренировка</label>
                <select asp-for="ExerciseId" class="form-control" asp-items="ViewBag.ExerciseId">
                    <option value="0">-- Избери тренировка --</option>
                </select>
                <span asp-validation-for="ExerciseId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Създай" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-controller="Exercises" asp-action="Index">Обратно към тренировките</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}