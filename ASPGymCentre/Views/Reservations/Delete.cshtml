@model ASPGymCentre.Models.Reservation

@{
    ViewData["Title"] = "Изтриване";
}

<h1>Изтриване</h1>

<div class="details-box">
    <h3>Сигурни ли сте, че искате да изтриете това?</h3>

    <h4>Резервация</h4>
    <hr />

    <div class="details-grid">
        <div class="details-label">Клиент</div>
        <div class="details-value">@Model.Clients?.UserName</div>

        <div class="details-label">План</div>
        <div class="details-value">@Model.Exercises?.Plans?.Name</div>

        <div class="details-label">Ден</div>
        <div class="details-value">@Model.Exercises?.Day</div>

        <div class="details-label">Час</div>
        <div class="details-value">@Model.Exercises?.StartTime - @Model.Exercises?.EndTime</div>

        <div class="details-label">Инструктор</div>
        <div class="details-value">@Model.Exercises?.Instructors?.Name</div>

        <div class="details-label">Дата на регистрация</div>
        <div class="details-value">@Model.RegisteredDate</div>
    </div>

    <form asp-action="Delete" method="post" class="page-actions">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Изтрий" class="btn btn-danger btn-sm action-btn" />
        <a asp-action="Index" class="btn btn-secondary btn-sm page-btn">Обратно към списъка</a>
    </form>
</div>