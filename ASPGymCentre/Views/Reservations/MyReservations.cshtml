@model IEnumerable<ASPGymCentre.Models.Reservation>
@using ASPGymCentre.Models

@{
    ViewData["Title"] = "Моите резервации";
    var availableExercises = ViewBag.AvailableExercises as List<Exercise>
        ?? new List<Exercise>();
}

<div class="section-title-row">

    <h1>Моите резервации</h1>

</div>


@if (TempData["ReservationSuccess"] != null)
{
    <div class="alert alert-success">
        @TempData["ReservationSuccess"]
    </div>
}


@if (TempData["ReservationError"] != null)
{
    <div class="alert alert-danger">
        @TempData["ReservationError"]
    </div>
}



<div class="info-page-box mb-4">

    <form method="get">

        <div class="row g-3">

            <div class="col-md-4">

                <select name="planId"
                        class="form-control"
                        asp-items="ViewBag.PlanId">

                    <option value="">
                        Всички планове
                    </option>

                </select>

            </div>


            <div class="col-md-4">

                <select name="searchDay"
                        class="form-control"
                        asp-items="ViewBag.Days">

                    <option value="">
                        Всички дни
                    </option>

                </select>

            </div>


            <div class="col-md-4">

                <select name="instructorId"
                        class="form-control"
                        asp-items="ViewBag.InstructorId">

                    <option value="">
                        Всички инструктори
                    </option>

                </select>

            </div>

        </div>


        <div class="page-actions mt-3">

            <button class="btn btn-primary">
                Филтрирай
            </button>


            <a asp-action="MyReservations"
               class="btn btn-secondary">

                Изчисти

            </a>

        </div>

    </form>

</div>



<h2 class="mb-4">Свободни тренировки</h2>


@if (availableExercises.Any())
{
    <div class="card-grid">

        @foreach (var exercise in availableExercises)
        {
            var alreadyReserved =
            Model.Any(x => x.ExerciseId == exercise.Id);

            var reservedCount =
            exercise.Reservations?.Count ?? 0;

            var freeSpots =
            15 - reservedCount;


            <div class="custom-card">

                <img src="@($"/images/{exercise.Plans.Image}")"
                     class="custom-card-img">


                <div class="custom-card-body">

                    <div class="badge-soft">
                        @exercise.Plans?.Name
                    </div>


                    <h3 class="custom-card-title">
                        @exercise.Day
                    </h3>


                    <div class="custom-card-meta">
                        <strong>Час:</strong>
                        @exercise.StartTime - @exercise.EndTime
                    </div>


                    <div class="custom-card-meta">
                        <strong>Инструктор:</strong>
                        @exercise.Instructors?.Name
                    </div>


                    <div class="custom-card-meta">
                        <strong>Цена:</strong>
                        @exercise.Plans?.PriceSingleWorkout €
                    </div>


                    <div class="custom-card-meta">
                        <strong>Свободни места:</strong>
                        @freeSpots / 15
                    </div>


                    <div class="custom-card-footer">

                        @if (alreadyReserved)
                        {
                            <button class="btn btn-success btn-sm"
                                    disabled>

                                Резервирана

                            </button>
                        }
                        else if (freeSpots <= 0)
                        {
                            <button class="btn btn-danger btn-sm"
                                    disabled>

                                Запълнена

                            </button>
                        }
                        else
                        {
                            <form asp-action="Reserve"
                                  method="post">

                                @Html.AntiForgeryToken()

                                <input type="hidden"
                                       name="exerciseId"
                                       value="@exercise.Id" />


                                <button class="btn btn-primary btn-sm">

                                    Резервирай

                                </button>

                            </form>
                        }

                    </div>

                </div>

            </div>
        }

    </div>
}
else
{
    <div class="empty-box">
        Няма тренировки по зададените критерии.
    </div>
}



<hr class="my-5" />


<h2 class="mb-4">Активни резервации</h2>


@if (Model.Any())
{
    <div class="card-grid">

        @foreach (var item in Model)
        {
            <div class="custom-card">

                <img src="@($"/images/{item.Exercises.Plans.Image}")"
                     class="custom-card-img">


                <div class="custom-card-body">

                    <div class="badge-soft">
                        @item.Exercises?.Plans?.Name
                    </div>


                    <h3 class="custom-card-title">
                        @item.Exercises?.Day
                    </h3>


                    <div class="custom-card-meta">
                        <strong>Час:</strong>
                        @item.Exercises?.StartTime - @item.Exercises?.EndTime
                    </div>


                    <div class="custom-card-meta">
                        <strong>Инструктор:</strong>
                        @item.Exercises?.Instructors?.Name
                    </div>


                    <div class="custom-card-meta">
                        <strong>Цена:</strong>
                        @item.Exercises?.Plans?.PriceSingleWorkout €
                    </div>


                    <div class="custom-card-meta">
                        <strong>Резервирана на:</strong>
                        @item.RegisteredDate.ToShortDateString()
                    </div>


                    <form asp-action="CancelMine"
                          method="post">

                        @Html.AntiForgeryToken()

                        <input type="hidden"
                               name="id"
                               value="@item.Id" />


                        <button class="btn btn-danger btn-sm">

                            Откажи

                        </button>

                    </form>

                </div>

            </div>
        }

    </div>
}
else
{
    <div class="empty-box">
        Нямаш активни резервации.
    </div>
}